    "id": "custom-synthetic-tabs",
    "name": "Custom Synthetic Tabs",
    "author": "yourname",
    "description": "Adds a custom tab to the UI that loads a synthetic HTML page with its own isolated JS/CSS.",
    "version": "1.0.1",
    "jellyfin": "10.10+",
    "tags": ["ui", "server"],
    "previewUrl": "https://cdn.jsdelivr.net/gh/Jellyfin-PG/JellyFrame-Resources@main/mods/custom-tab.png",
    "sourceUrl": "https://jellyfin-pg.github.io/JellyFrame/",
    "cssUrl": null,
    "jsUrl": "https://cdn.jsdelivr.net/gh/Jellyfin-PG/JellyFrame-Resources@main/mods/custom-tab-client.js",
    "serverJs": "https://cdn.jsdelivr.net/gh/Jellyfin-PG/JellyFrame-Resources@main/mods/custom-tab-server.js",
    "permissions": [],
    "requires": [],
    "vars": [
      {
        "key": "TAB_NAME",
        "name": "Tab Name",
        "description": "The label shown on the custom tab.",
        "type": "text",
        "default": "Custom Page"
      },
      {
        "key": "TAB_TOP_OFFSET",
        "name": "Tab Top Offset",
        "description": "Adjust this based on your theme to place the page perfectly under the top bar.",
        "type": "text",
        "default": "115px"
      },
      {
        "key": "CUSTOM_HTML",
        "name": "Custom HTML Content",
        "description": "The raw HTML, CSS, and JS to load inside the synthetic page.",
        "type": "text",
        "default": "<!DOCTYPE html><html><head><style>body { color: white; font-family: sans-serif; padding: 2rem; }</style></head><body><h1>Welcome to your custom page!</h1><button onclick=\"alert('JS works!')\">Test JS</button></body></html>"
      }
    ]
  },
  {
    "id": "media-bar",
    "name": "Media Bar",
    "author": "grimmdev",
    "description": "A featured content slideshow bar on the Jellyfin home page. Showcases backdrop images, logos, ratings, genres, and plot summaries for your media with auto-advancing slides, navigation arrows, and play/detail/favourite buttons. Configure a playlist ID for curated content or let it pick from your latest additions automatically.",
    "version": "1.0.3",
    "jellyfin": "10.10+",
    "tags": [
      "home",
      "slideshow",
      "featured",
      "ui"
    ],
    "previewUrl": "https://cdn.jsdelivr.net/gh/Jellyfin-PG/JellyFrame-Resources@main/mods/media-bar.png",
    "sourceUrl": "https://jellyfin-pg.github.io/JellyFrame/",
    "cssUrl": "https://cdn.jsdelivr.net/gh/Jellyfin-PG/JellyFrame-Resources@main/mods/media-bar-style.css",
    "jsUrl": "https://cdn.jsdelivr.net/gh/Jellyfin-PG/JellyFrame-Resources@main/mods/media-bar-client.js",
    "serverJs": "https://cdn.jsdelivr.net/gh/Jellyfin-PG/JellyFrame-Resources@main/mods/media-bar-server.js",
    "permissions": [
      "jellyfin.read",
      "jellyfin.write",
      "store",
      "scheduler"
    ],
    "requires": ["home-app-layout"],
    "preconnect": [],
    "vars": [
      {
        "key": "PLAYLIST_ID",
        "name": "Playlist ID",
        "description": "Jellyfin item ID of a playlist to use as the source for the bar. Leave blank to use the latest additions from your library.",
        "type": "text",
        "default": ""
      },
      {
        "key": "ITEM_IDS",
        "name": "Manual Item IDs",
        "description": "Comma-separated list of Jellyfin item IDs to feature. Ignored if Playlist ID is set.",
        "type": "text",
        "default": ""
      },
      {
        "key": "ITEM_COUNT",
        "name": "Number of Items",
        "description": "How many items to show in the bar (1–20).",
        "type": "number",
        "default": "10"
      },
      {
        "key": "SLIDE_INTERVAL",
        "name": "Slide Interval (ms)",
        "description": "How long each slide is shown before auto-advancing. Default is 8000 (8 seconds).",
        "type": "number",
        "default": "8000"
      },
      {
        "key": "SHUFFLE",
        "name": "Shuffle Items",
        "description": "Randomise the order of items each time the bar loads.",
        "type": "boolean",
        "default": "true"
      }
    ]
  },
