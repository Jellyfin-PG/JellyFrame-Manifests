[
  {
    "id": "media-bar",
    "name": "Media Bar",
    "author": "grimmdev",
    "description": "A featured content slideshow bar on the Jellyfin home page. Showcases backdrop images, logos, ratings, genres, and plot summaries for your media with auto-advancing slides, navigation arrows, and play/detail/favourite buttons. Configure a playlist ID for curated content or let it pick from your latest additions automatically.",
    "version": "1.0.3",
    "jellyfin": "10.10+",
    "tags": [
      "home",
      "slideshow",
      "featured",
      "ui"
    ],
    "previewUrl": "https://cdn.jsdelivr.net/gh/Jellyfin-PG/JellyFrame-Resources@main/mods/media-bar.png",
    "sourceUrl": "https://github.com/Jellyfin-PG/JellyFrame-Resources",
    "cssUrl": "https://cdn.jsdelivr.net/gh/Jellyfin-PG/JellyFrame-Resources@main/mods/media-bar-style.css",
    "jsUrl": "https://cdn.jsdelivr.net/gh/Jellyfin-PG/JellyFrame-Resources@main/mods/media-bar-client.js",
    "serverJs": "https://cdn.jsdelivr.net/gh/Jellyfin-PG/JellyFrame-Resources@main/mods/media-bar-server.js",
    "permissions": [
      "jellyfin.read",
      "jellyfin.write",
      "store",
      "scheduler"
    ],
    "requires": [],
    "preconnect": [],
    "vars": [
      {
        "key": "PLAYLIST_ID",
        "name": "Playlist ID",
        "description": "Jellyfin item ID of a playlist to use as the source for the bar. Leave blank to use the latest additions from your library.",
        "type": "text",
        "default": ""
      },
      {
        "key": "ITEM_IDS",
        "name": "Manual Item IDs",
        "description": "Comma-separated list of Jellyfin item IDs to feature. Ignored if Playlist ID is set.",
        "type": "text",
        "default": ""
      },
      {
        "key": "ITEM_COUNT",
        "name": "Number of Items",
        "description": "How many items to show in the bar (1–20).",
        "type": "number",
        "default": "10"
      },
      {
        "key": "SLIDE_INTERVAL",
        "name": "Slide Interval (ms)",
        "description": "How long each slide is shown before auto-advancing. Default is 8000 (8 seconds).",
        "type": "number",
        "default": "8000"
      },
      {
        "key": "SHUFFLE",
        "name": "Shuffle Items",
        "description": "Randomise the order of items each time the bar loads.",
        "type": "boolean",
        "default": "true"
      }
    ]
  },
  {
    "id": "are-you-still-watching",
    "name": "Are you still watching?",
    "author": "grimmdev",
    "description": "Shows an 'Are you still watching?' prompt after a period of inactivity during playback. If not dismissed, the player exits automatically. Fully configurable timing, text, and colours.",
    "version": "1.0.0",
    "jellyfin": "10.10+",
    "tags": [
      "player",
      "idle",
      "utility"
    ],
    "previewUrl": "https://cdn.jsdelivr.net/gh/Jellyfin-PG/JellyFrame-Resources@main/mods/are-you-still-watching.png",
    "sourceUrl": "https://github.com/Jellyfin-PG/JellyFrame-Resources",
    "cssUrl": null,
    "jsUrl": "https://cdn.jsdelivr.net/gh/Jellyfin-PG/JellyFrame-Resources@main/mods/are-you-still-watching-client.js",
    "serverJs": null,
    "permissions": [],
    "requires": [],
    "vars": [
      {
        "key": "IDLE_MINUTES",
        "name": "Idle Time (minutes)",
        "description": "How many minutes of uninterrupted playback before the prompt appears. Default is 180 (3 hours).",
        "type": "number",
        "default": "180"
      },
      {
        "key": "PROMPT_SECONDS",
        "name": "Prompt Timeout (seconds)",
        "description": "How many seconds the prompt stays on screen before the player exits. Default is 60.",
        "type": "number",
        "default": "60"
      },
      {
        "key": "PROMPT_TEXT",
        "name": "Prompt Message",
        "description": "The heading text shown on the prompt overlay.",
        "type": "text",
        "default": "Are you still watching?"
      },
      {
        "key": "BUTTON_TEXT",
        "name": "Button Label",
        "description": "Text on the continue watching button.",
        "type": "text",
        "default": "Continue Watching"
      },
      {
        "key": "BUTTON_COLOR",
        "name": "Button Color",
        "description": "Background color of the continue watching button.",
        "type": "color",
        "default": "#10b981"
      },
      {
        "key": "TEXT_COLOR",
        "name": "Text Color",
        "description": "Color of the prompt heading and countdown text.",
        "type": "color",
        "default": "#ffffff"
      },
      {
        "key": "OVERLAY_COLOR",
        "name": "Overlay Background",
        "description": "Background color of the overlay. Use rgba() for transparency, e.g. rgba(0,0,0,0.85).",
        "type": "text",
        "default": "rgba(0,0,0,0.85)"
      }
    ]
  },
  {
    "id": "media-request",
    "name": "Media Request",
    "author": "grimmdev",
    "description": "Adds a Request Media button to the left-hand navigation menu. Users can submit requests for movies, TV shows, music, or any configured media type. Requests are stored server-side and optionally forwarded to a webhook (Discord, Slack, custom).",
    "version": "1.0.2",
    "jellyfin": "10.10+",
    "tags": [
      "ui",
      "requests",
      "community"
    ],
    "previewUrl": "https://cdn.jsdelivr.net/gh/Jellyfin-PG/JellyFrame-Resources@main/mods/media-request.png",
    "sourceUrl": "https://github.com/Jellyfin-PG/JellyFrame-Resources",
    "cssUrl": null,
    "jsUrl": "https://cdn.jsdelivr.net/gh/Jellyfin-PG/JellyFrame-Resources@main/mods/media-request-client.js",
    "serverJs": "https://cdn.jsdelivr.net/gh/Jellyfin-PG/JellyFrame-Resources@main/mods/media-request-server.js",
    "permissions": [
      "store",
      "webhooks"
    ],
    "requires": [],
    "vars": [
      {
        "key": "MENU_LABEL",
        "name": "Menu Button Label",
        "description": "Text shown on the navigation menu button.",
        "type": "text",
        "default": "Request Media"
      },
      {
        "key": "ACCENT_COLOR",
        "name": "Accent Color",
        "description": "Color used for the submit button and input focus ring.",
        "type": "color",
        "default": "#00a4dc"
      },
      {
        "key": "ALLOW_TYPES",
        "name": "Media Types",
        "description": "Comma-separated list of request types shown in the dropdown. e.g. Movie, TV Show, Music, Anime, Other",
        "type": "text",
        "default": "Movie, TV Show, Music, Anime, Other"
      },
      {
        "key": "WEBHOOK_URL",
        "name": "Webhook URL",
        "description": "Optional. POST each new request to this URL (Discord, Slack, or any HTTP endpoint). Leave blank to disable.",
        "type": "text",
        "default": ""
      },
      {
        "key": "WEBHOOK_SECRET",
        "name": "Webhook Secret",
        "description": "Optional. If set, signs the webhook payload with HMAC-SHA256 and adds an X-Hub-Signature-256 header.",
        "type": "text",
        "default": ""
      }
    ]
  },
